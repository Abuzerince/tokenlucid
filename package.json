{
  "name": "tokenlucid",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "test": "vitest run",
    "check": "npm run test && npm run build",
    "token:wallet": "tsx scripts/create-dev-wallet.ts",
    "token:preflight": "tsx scripts/preflight.ts",
    "token:create": "tsx scripts/create-token.ts",
    "token:recover": "tsx scripts/recover-token.ts",
    "token:verify": "tsx scripts/verify-token.ts",
    "token:distribute": "tsx scripts/distribute-token.ts",
    "token:lock-founder": "tsx scripts/create-devnet-founder-lock.ts",
    "token:multisig-treasury": "tsx scripts/create-devnet-treasury-multisig.ts",
    "listing:check": "tsx scripts/check-listing-readiness.ts",
    "release:manifest": "tsx scripts/generate-release-manifest.ts"
  },
  "dependencies": {
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.2.0",
    "tsx": "4.22.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@metaplex-foundation/mpl-token-metadata": "3.4.0",
    "@metaplex-foundation/mpl-toolbox": "0.11.4",
    "@metaplex-foundation/umi": "1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "1.5.1",
    "@resvg/resvg-js": "2.6.2",
    "@solana/spl-token": "0.4.14",
    "@solana/web3.js": "1.98.4",
    "@streamflow/stream": "12.5.0",
    "@types/express": "5.0.6",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "lucide-react": "1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "vite": "8.1.2",
    "vitest": "4.1.10"
  }
}
